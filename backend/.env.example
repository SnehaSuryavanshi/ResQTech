# ResQAI Server Environment Variables
# Copy this file to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/resqai?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=resqai_super_secret_jwt_key_2024_emergency
JWT_EXPIRE=30d

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps (server-side key for directions/places)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email (Nodemailer - Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
